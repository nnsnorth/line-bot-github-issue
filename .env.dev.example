# Dev environment LINE OA credentials
# Create a separate LINE channel at https://developers.line.biz/console/
# for the dev environment and copy the credentials here.
LINE_CHANNEL_SECRET=your_dev_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_dev_channel_access_token_here

# GitHub App integration — for creating support issues via @support <description>
GITHUB_APP_ID=your_github_app_id
# Both PKCS#1 (BEGIN RSA PRIVATE KEY) and PKCS#8 (BEGIN PRIVATE KEY) formats are accepted.
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_INSTALLATION_ID=your_installation_id
GITHUB_OWNER=your_github_org_or_username
GITHUB_REPO=your_github_repo_name

# GitHub Projects V2 — auto-classification into project board fields
GITHUB_PROJECT_NUMBER=5

# Self-hosted classifier service URL (Cloud Run)
CLASSIFIER_URL=

# Classifier confidence threshold (default: 0.70)
# CONFIDENCE_THRESHOLD=0.70

# Server port (Cloud Run uses 8080; use 3000 locally)
PORT=3000

# Environment label (used in logs)
NODE_ENV=development
