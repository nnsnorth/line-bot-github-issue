# LINE Messaging API credentials
# Obtain these from the LINE Developers Console:
# https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# GitHub App integration — for creating support issues via @support <description>
# Register a GitHub App at https://github.com/settings/apps
# Grant it "Issues: Read & write" and "Projects: Read & write" permissions,
# then install it on the target repo/org.
GITHUB_APP_ID=your_github_app_id
# PEM private key — replace actual newlines with \n so it fits on one line.
# Both PKCS#1 (BEGIN RSA PRIVATE KEY) and PKCS#8 (BEGIN PRIVATE KEY) formats are accepted.
# Alternatively, base64-encode the entire PEM.
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_INSTALLATION_ID=your_installation_id
GITHUB_OWNER=your_github_org_or_username
GITHUB_REPO=your_github_repo_name

# GitHub Projects V2 — set to enable auto-classification into project fields.
# The project number from https://github.com/orgs/<org>/projects/<number>
GITHUB_PROJECT_NUMBER=5

# Self-hosted classifier service URL (Cloud Run).
# Example: https://your-classifier-xxxxx-as.a.run.app
CLASSIFIER_URL=

# Classifier confidence threshold (0-1). Each field is only filled
# if its confidence meets this threshold. Default: 0.70
# CONFIDENCE_THRESHOLD=0.70

# Server port (default: 3000)
PORT=3000

# Maps tenant names to one or more LINE group/room IDs (JSON object).
# Messages from these groups skip classifier tenant detection and use the mapped tenant directly.
# A single tenant can own multiple groups. All non-mention messages in groups are silently ignored.
# Example: {"hospital_a": ["Cxxx...", "Cyyy..."], "hospital_b": "Czzz..."}
LINE_GROUP_TENANT_MAP={}
